# =============================================================================
# wcWIKI Environment Variables
# Copy this file to .env.local for local dev, or set in Portainer for production.
# NEVER commit real secrets to this file.
# =============================================================================

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL="postgresql://wcwiki:wcwiki@localhost:5432/wcwiki?schema=public"
# Production: POSTGRES_PASSWORD is set separately in docker-compose.prod.yml

# ── Meilisearch (Full-Text Search) ─────────────────────────────────────────
MEILISEARCH_HOST="http://127.0.0.1:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# ── NextAuth (Authentication) ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"
# Generate: openssl rand -base64 32

# ── Google OAuth (NextAuth Provider) ───────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Public URLs ────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://wcwiki.org"

# AI metadata suggestions for painting reference uploads
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-5.4-mini"
OPENAI_METADATA_DAILY_LIMIT="10"

# ── Cloudflare R2 (Image Storage) ──────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="wcwiki-images"
R2_PUBLIC_URL="https://images.wcwiki.org"

# ── Production-Only (set in Portainer stack, not needed for local dev) ─────
# POSTGRES_PASSWORD=""      # PostgreSQL password for docker-compose.prod.yml
# MEILI_MASTER_KEY=""        # Meilisearch master key for docker-compose.prod.yml
# CF_TUNNEL_TOKEN=""         # Cloudflare Tunnel token
# CRON_SECRET=""             # Enables daily search analytics aggregation cron
